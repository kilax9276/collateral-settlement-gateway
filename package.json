{
  "name": "collateral-settlement-gateway",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "A Web3 settlement gateway for on-chain collateral, signed off-chain intents, auditable settlement, and operational reconciliation.",
  "scripts": {
    "chain": "hardhat node",
    "compile": "hardhat compile",
    "deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network sepolia",
    "deploy:arbitrum-sepolia": "hardhat run scripts/deploy.ts --network arbitrumSepolia",
    "verify:sepolia": "tsx scripts/verify-testnet.ts sepolia",
    "verify:arbitrum-sepolia": "tsx scripts/verify-testnet.ts arbitrumSepolia",
    "dev:backend": "tsx watch backend/src/server.ts",
    "start:backend": "node dist/backend/src/server.js",
    "build": "tsc -p tsconfig.json",
    "test": "npm run test:contracts && npm run test:backend",
    "test:contracts": "hardhat test test/contracts/*.test.ts",
    "test:backend": "vitest run test/backend --maxWorkers=1 --minWorkers=1 --pool=forks",
    "test:e2e": "vitest run test/e2e/fullProject.test.ts --maxWorkers=1 --minWorkers=1 --pool=threads",
    "demo:e2e": "tsx scripts/demo-e2e.ts",
    "ws:client": "tsx scripts/websocket-client.ts",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "demo:indexer": "hardhat run scripts/demo-indexed-deposit.ts --network localhost",
    "dev:frontend": "npm run local:frontend",
    "demo:full": "tsx scripts/demo-full.ts",
    "local:chain": "hardhat node --hostname 0.0.0.0",
    "local:deploy": "hardhat run scripts/deploy.ts --network localhost",
    "local:backend": "tsx backend/src/server.ts",
    "local:frontend": "tsx scripts/dev-frontend.ts",
    "wait:rpc": "tsx scripts/wait-for-rpc.ts",
    "local:reset": "tsx scripts/reset-local-state.ts",
    "demo:prepare": "tsx scripts/prepare-demo.ts",
    "settlement:report": "tsx scripts/settlement-report.ts",
    "example:external-client": "tsx examples/external-client/client.ts",
    "dev": "tsx scripts/dev.ts"
  },
  "dependencies": {
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@fastify/websocket": "^11.0.1",
    "@openzeppelin/contracts": "^5.0.2",
    "dotenv": "^16.4.7",
    "fastify": "^5.4.0",
    "nanoid": "^5.1.5",
    "viem": "^2.22.17",
    "ws": "^8.21.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@nomicfoundation/hardhat-ignition": "^3.1.7",
    "@nomicfoundation/hardhat-ignition-viem": "^3.1.6",
    "@nomicfoundation/hardhat-keystore": "^3.0.12",
    "@nomicfoundation/hardhat-network-helpers": "^3.0.10",
    "@nomicfoundation/hardhat-node-test-runner": "^3.0.17",
    "@nomicfoundation/hardhat-toolbox-viem": "^5.0.7",
    "@nomicfoundation/hardhat-verify": "^3.0.19",
    "@nomicfoundation/hardhat-viem": "^3.0.9",
    "@nomicfoundation/hardhat-viem-assertions": "^3.1.1",
    "@types/node": "^22.10.7",
    "@types/ws": "^8.18.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "hardhat": "^3.9.0",
    "prettier": "^3.4.2",
    "prettier-plugin-solidity": "^1.4.1",
    "solc": "^0.8.24",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "web3",
    "solidity",
    "settlement",
    "collateral",
    "fastify",
    "typescript",
    "viem",
    "eip-712",
    "defi",
    "audit-trail"
  ],
  "license": "MIT",
  "author": "Aleksei Kolobov"
}
