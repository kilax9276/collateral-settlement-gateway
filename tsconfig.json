{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": ".",
    "types": ["node", "vitest/globals"],
    "verbatimModuleSyntax": true
  },
  "include": [
    "backend/src/**/*.ts",
    "scripts/**/*.ts",
    "examples/**/*.ts",
    "test/**/*.ts",
    "hardhat.config.ts"
  ]
}
