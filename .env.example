# Collateral Settlement Gateway local/default environment

# HTTP server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Blockchain / deployment metadata
RPC_URL=http://127.0.0.1:8545
CHAIN_ID=31337
CONTRACTS_FILE=backend/src/generated/contracts.json
OPERATOR_PRIVATE_KEY=
OPERATOR_ADDRESS=
ALICE_PRIVATE_KEY=

# Indexer
INDEXER_ENABLED=true
INDEXER_POLL_INTERVAL_MS=1000

# Storage
STORAGE_DRIVER=sqlite
SQLITE_PATH=backend/data/app.db

# reference implementation gateway authorization placeholders
# These values are intentionally simple local defaults. Replace them in any shared/demo environment.
GATEWAY_ADMIN_TOKEN=change-me-admin-token
REGISTERED_APPS=trading-example:change-me-trading-secret,fantasy-trading-app:change-me-external-secret

# Trading reference example
DEFAULT_SYMBOL=BTC-USD
DEFAULT_BTC_PRICE=65000
SUPPORTED_SYMBOLS=BTC-USD
MAX_LEVERAGE=5
MAX_POSITION_NOTIONAL=100000
MIN_COLLATERAL=0
MAX_PRICE_AGE_MS=60000
TAKER_FEE_BPS=5
QUOTE_TICK_MS=1000

# Market data providers: mock | coingecko | pyth
MARKET_DATA_PROVIDER=mock
COINGECKO_API_KEY=
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
PYTH_PRICE_FEED_ID=
PYTH_BASE_URL=https://hermes.pyth.network

# Demo-only local walkthrough routes and dashboard helpers
ENABLE_DEMO_ROUTES=false
DEMO_BACKEND_PORT=3000
DEMO_BACKEND_HOST=127.0.0.1
DEMO_WAIT_TIMEOUT_MS=60000
DEMO_RESET_DB=true
DEPOSIT_AMOUNT=10000

# Local frontend helper
FRONTEND_PORT=5173
FRONTEND_HOST=127.0.0.1
BACKEND_URL=http://127.0.0.1:3000

# CLI / examples
API_URL=http://127.0.0.1:3000
GATEWAY_URL=http://127.0.0.1:3000
WS_URL=ws://localhost:3000/ws
EXTERNAL_APP_ID=fantasy-trading-app
EXTERNAL_APP_SECRET=change-me-external-secret
EXTERNAL_SETTLEMENT_TYPE=EXTERNAL_APP_REWARD
EXTERNAL_REWARD_AMOUNT=25
EXTERNAL_ROUND_ID=fantasy-round-001
EXTERNAL_MARKET_ID=weekly-btc-contest
EXTERNAL_OUTCOME=top-10-finish
EXTERNAL_APP_PRIVATE_KEY=
EXTERNAL_CLIENT_ACCOUNT_INDEX=1

# Testnet deployment / verification
SEPOLIA_RPC_URL=
ARBITRUM_SEPOLIA_RPC_URL=
DEPLOYER_PRIVATE_KEY=
ETHERSCAN_API_KEY=
WAIT_TIMEOUT_MS=60000
WAIT_INTERVAL_MS=1000
